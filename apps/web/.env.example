NUXT_APP_NAME=NODEWAVE.NET
NUXT_PUBLIC_SITE_URL=https://nodewave.net
NUXT_OG_IMAGE_SECRET=my-og-secret

# BLOGGING
# NUXT_STRAPI_API_URL=http://localhost:1337
NUXT_STRAPI_API_URL=<strapiurl>
NUXT_EMAIL_API_URL=<mailerurl>

# ANALYTICS CONFIGURATION

# Google Tag Manager Container ID (required for analytics)
# Get this from https://tagmanager.google.com/
NUXT_GTM_CONTAINER_ID=GTM-XXXXXXX

# Google Analytics 4 Measurement ID
# Get this from https://analytics.google.com/
NUXT_GA_MEASUREMENT_ID=G-XXXXXXXXXX

NUXT_PUBLIC_TURNSTILE_SITE_KEY=<turnstilesitekey>
NUXT_TURNSTILE_SECRET_KEY=<turnstilesecretkey>

# EMAIL CONFIGURATION
# Provider selection: 'smtp', 'gmail', or 'nodemailer'
NUXT_SMTP_PROVIDER=nodemailer

# Email address to receive contact form submissions
NUXT_CONTACT_EMAIL=<contactemail>

# SMTP Provider Configuration (for NUXT_SMTP_PROVIDER=smtp)
# NUXT_SMTP_HOST=smtp.gmail.com
# NUXT_SMTP_PORT=587
# NUXT_SMTP_USER=your-email@gmail.com
# NUXT_SMTP_PASS=your-app-specific-password
# NUXT_SMTP_FROM_EMAIL=your-email@gmail.com

# Gmail Provider Configuration (for NUXT_SMTP_PROVIDER=gmail)
# NUXT_GMAIL_USER=your-email@gmail.com
# NUXT_GMAIL_APP_PASSWORD=your-app-specific-password

# Nodemailer Provider Configuration (for NUXT_SMTP_PROVIDER=nodemailer)
# NUXT_NODEMAILER_HOST=smtp.example.com
# NUXT_NODEMAILER_PORT=587
# NUXT_NODEMAILER_USER=your-email@example.com
# NUXT_NODEMAILER_PASS=your-password
# NUXT_NODEMAILER_FROM_EMAIL=your-email@example.com
