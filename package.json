{
  "author": "Gideon Maina & Gideon Yebei",
  "bugs": {
    "url": "https://github.com/NodeWave-EA/nodewave-redesigned/issues"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.104",
    "@iconify-json/simple-icons": "^1.2.80",
    "@nuxt/a11y": "^1.0.0-alpha.1",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/hints": "^1.0.3",
    "@nuxt/icon": "^2.2.1",
    "@nuxt/image": "^2.0.0",
    "@nuxt/scripts": "^1.0.2",
    "@nuxt/ui": "^4.7.0",
    "@nuxtjs/color-mode": "4.0.0",
    "@nuxtjs/seo": "^5.1.3",
    "@pinia/nuxt": "^0.11.3",
    "@resvg/resvg-js": "^2.6.2",
    "@vueuse/motion": "^3.0.3",
    "@vueuse/nuxt": "^14.2.1",
    "nuxt": "^4.4.2",
    "nuxt-aos": "^1.2.6",
    "satori": "^0.26.0",
    "tailwindcss": "^4.2.4"
  },
  "description": "Official website for NodeWave EA",
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@types/aos": "^3.0.7",
    "eslint": "^10.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^6.0.3",
    "vue-tsc": "^3.2.7"
  },
  "homepage": "https://nodewave.net",
  "license": "MIT",
  "lint-staged": {
    "*.{css,scss,html,md}": [
      "prettier --write"
    ],
    "*.{js,ts,vue}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "name": "nodewave-ea-website",
  "packageManager": "bun@1.3.13",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NodeWave-EA/nodewave-redesigned"
  },
  "scripts": {
    "build": "bun --bun nuxt build",
    "dev": "bun --bun nuxt dev",
    "lint": "bun --bun eslint . --fix",
    "postinstall": "bun --bun nuxt prepare",
    "prepare": "husky",
    "preview": "bun --bun nuxt preview",
    "typecheck": "bun --bun nuxt typecheck",
    "format": "prettier --write ."
  },
  "type": "module",
  "version": "1.0.0"
}
